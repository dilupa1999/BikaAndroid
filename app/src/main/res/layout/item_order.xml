<?xml version="1.0" encoding="utf-8"?>
<!-- item_product_card.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foregroundTint="#F9A825"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="383dp"
        android:layout_height="142dp"
        android:backgroundTint="#100F0F"
        android:foregroundTint="#070707"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/cartimage"
            android:layout_width="124dp"
            android:layout_height="79dp"
            android:layout_weight="1"



            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"


         />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:scrollbarThumbVertical="@drawable/circle_shape">

            <TextView
                android:id="@+id/orderid"
                android:layout_width="match_parent"
                android:layout_height="29dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="5dp"
                android:text="Buriyani"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/totel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accompanied with Roasted Whole Chicken, Cashew  Green Pea Curry, Pineapple Chutney or Tempered Potato, Boiled  Fried Egg"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/adress"
                android:layout_width="360dp"
                android:layout_height="52dp"
                android:text="1200.00"
                android:textAlignment="center" />


        </LinearLayout>
    </LinearLayout>
</LinearLayout>
