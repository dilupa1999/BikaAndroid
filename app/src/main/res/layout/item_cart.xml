<?xml version="1.0" encoding="utf-8"?>
<!-- item_product_card.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="383dp"
        android:layout_height="148dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/cartimage"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"


            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"

            />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/cartname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Buriyani"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/productdesc"
                android:layout_width="265dp"
                android:layout_height="65dp"
                android:text="Accompanied with Roasted Whole Chicken, Cashew  Green Pea Curry, Pineapple Chutney or Tempered Potato, Boiled  Fried Egg"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/cartprice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1200.00"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/cartqty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4"
                android:textAlignment="center" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
